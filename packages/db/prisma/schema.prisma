// ContentForge – Prisma Schema
// Stack: PostgreSQL via Supabase / Neon

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum Role {
  CREATOR
  EDITOR
  ADMIN
  SUPER_ADMIN
}

enum SubscriptionTier {
  FREE
  BASIC
  GROWTH
  PREMIUM
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  PAUSED
}

enum IdeaStatus {
  DRAFT
  SUBMITTED
  IN_REVIEW
  APPROVED
  SCRIPTED
  ARCHIVED
}

enum ScriptStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  REVISION_REQUESTED
  PUBLISHED
}

enum VideoStatus {
  UPLOADING
  PROCESSING
  READY
  FAILED
  ARCHIVED
}

enum ClipStatus {
  PENDING
  PROCESSING
  READY
  FAILED
}

enum PostStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
  FAILED
  CANCELLED
}

enum AutomationTriggerType {
  COMMENT_KEYWORD
  DM_KEYWORD
  POST_REACTION
  STORY_REPLY
}

enum AutomationActionType {
  SEND_DM
  SEND_COMMENT_REPLY
  TAG_USER
  ADD_TO_LIST
  WEBHOOK
}

enum ContentPillarType {
  EDUCATION
  ENTERTAINMENT
  INSPIRATION
  PROMOTION
  BEHIND_THE_SCENES
  COMMUNITY
}

enum Platform {
  TIKTOK
  INSTAGRAM
  YOUTUBE
  TWITTER_X
  LINKEDIN
  FACEBOOK
  PINTEREST
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
  REVISION_REQUESTED
}

// ─────────────────────────────────────────────
// USERS & ORGS
// ─────────────────────────────────────────────

model User {
  id            String   @id @default(cuid())
  clerkId       String   @unique
  email         String   @unique
  name          String
  avatarUrl     String?
  role          Role     @default(CREATOR)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  organization   Organization? @relation(fields: [organizationId], references: [id])
  organizationId String?

  creatorProfile CreatorProfile?
  auditLogs      AuditLog[]
  reviewActions  AdminReview[]

  @@index([clerkId])
  @@index([email])
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  logoUrl   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users         User[]
  subscriptions Subscription[]
  billingRecords BillingRecord[]
}

// ─────────────────────────────────────────────
// CREATOR PROFILE
// ─────────────────────────────────────────────

model CreatorProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  displayName     String
  bio             String?
  timezone        String   @default("UTC")
  postingGoal     Int      @default(30) // posts per month
  onboardingDone  Boolean  @default(false)
  consentAiVoice  Boolean  @default(false)
  consentAiAvatar Boolean  @default(false)
  voiceCloneId    String?  // ElevenLabs voice ID
  avatarId        String?  // HeyGen avatar ID

  niches          NicheOnCreator[]
  influencers     InfluencerOnCreator[]
  ideas           ContentIdea[]
  videos          UploadedVideo[]
  socialAccounts  SocialAccount[]
  contentCalendar ContentCalendarItem[]
  automations     Automation[]
  blogPosts       BlogPost[]
  igConnection    IgConnection?
  igSubscribers   IgSubscriber[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────
// NICHES & INFLUENCERS
// ─────────────────────────────────────────────

model Niche {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  iconUrl     String?

  creators    NicheOnCreator[]
  influencers Influencer[]
  trends      TrendInsight[]
}

model NicheOnCreator {
  creator   CreatorProfile @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  creatorId String
  niche     Niche          @relation(fields: [nicheId], references: [id])
  nicheId   String
  isPrimary Boolean        @default(false)

  @@id([creatorId, nicheId])
}

model Influencer {
  id           String   @id @default(cuid())
  name         String
  handle       String
  platform     Platform
  profileUrl   String
  avatarUrl    String?
  followerCount Int?
  nicheId      String?
  niche        Niche?   @relation(fields: [nicheId], references: [id])
  analysisData Json?    // cached trend/style analysis
  lastAnalyzed DateTime?

  creators     InfluencerOnCreator[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model InfluencerOnCreator {
  creator      CreatorProfile @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  creatorId    String
  influencer   Influencer     @relation(fields: [influencerId], references: [id])
  influencerId String
  addedAt      DateTime       @default(now())

  @@id([creatorId, influencerId])
}

// ─────────────────────────────────────────────
// TREND INTELLIGENCE
// ─────────────────────────────────────────────

model TrendInsight {
  id        String   @id @default(cuid())
  nicheId   String
  niche     Niche    @relation(fields: [nicheId], references: [id])
  title     String
  summary   String
  source    String?
  rawData   Json?
  score     Float    @default(0)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

// ─────────────────────────────────────────────
// CONTENT IDEAS
// ─────────────────────────────────────────────

model ContentIdea {
  id          String      @id @default(cuid())
  creatorId   String
  creator     CreatorProfile @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  rawIdea     String      // creator's raw input
  refinedIdea String?     // AI-cleaned version
  status      IdeaStatus  @default(DRAFT)
  pillarType  ContentPillarType?
  tags        String[]

  scripts     Script[]
  adminReview AdminReview?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([creatorId, status])
}

// ─────────────────────────────────────────────
// SCRIPTS
// ─────────────────────────────────────────────

model Script {
  id          String       @id @default(cuid())
  ideaId      String
  idea        ContentIdea  @relation(fields: [ideaId], references: [id], onDelete: Cascade)

  title       String
  hook        String
  painPoint   String?
  authority   String?
  solution    String
  callToAction String
  fullScript  String       // assembled full text
  status      ScriptStatus @default(DRAFT)
  platform    Platform?    // platform-optimized version
  wordCount   Int?
  estimatedDuration Int?  // seconds

  versions    ScriptVersion[]
  clips       RepurposedClip[]
  calendarItems ContentCalendarItem[]
  adminReview  AdminReview?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ideaId, status])
}

model ScriptVersion {
  id        String   @id @default(cuid())
  scriptId  String
  script    Script   @relation(fields: [scriptId], references: [id], onDelete: Cascade)
  version   Int
  snapshot  Json     // full script data at this version
  editedBy  String?  // userId
  note      String?
  createdAt DateTime @default(now())
}

// ─────────────────────────────────────────────
// VIDEOS & REPURPOSING
// ─────────────────────────────────────────────

model UploadedVideo {
  id           String      @id @default(cuid())
  creatorId    String
  creator      CreatorProfile @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  title        String
  description  String?
  storagePath  String      // blob/storage URL
  duration     Int?        // seconds
  sizeBytes    BigInt?
  mimeType     String?
  status       VideoStatus @default(UPLOADING)
  transcript   String?
  metadata     Json?

  clips        RepurposedClip[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RepurposedClip {
  id          String     @id @default(cuid())
  videoId     String
  video       UploadedVideo @relation(fields: [videoId], references: [id], onDelete: Cascade)
  scriptId    String?
  script      Script?    @relation(fields: [scriptId], references: [id])

  title       String
  storagePath String?
  duration    Int?
  startTime   Float?
  endTime     Float?
  status      ClipStatus @default(PENDING)
  opusClipId  String?    // external job ID
  captions    String?
  hashtags    String[]
  postCopy    String?
  platform    Platform?
  metadata    Json?

  calendarItems ContentCalendarItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────
// SOCIAL ACCOUNTS & CALENDAR
// ─────────────────────────────────────────────

model SocialAccount {
  id          String   @id @default(cuid())
  creatorId   String
  creator     CreatorProfile @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  platform    Platform
  handle      String
  accessToken String?  // encrypted
  refreshToken String? // encrypted
  tokenExpiry DateTime?
  postizAccountId String? // Postiz channel ID
  isActive    Boolean  @default(true)

  scheduledPosts ScheduledPost[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([creatorId, platform])
}

model ContentCalendarItem {
  id          String   @id @default(cuid())
  creatorId   String
  creator     CreatorProfile @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  scriptId    String?
  script      Script?  @relation(fields: [scriptId], references: [id])
  clipId      String?
  clip        RepurposedClip? @relation(fields: [clipId], references: [id])

  title       String
  scheduledFor DateTime
  platform    Platform
  pillarType  ContentPillarType?
  notes       String?
  status      PostStatus @default(DRAFT)

  scheduledPost ScheduledPost?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([creatorId, scheduledFor])
}

model ScheduledPost {
  id              String   @id @default(cuid())
  calendarItemId  String   @unique
  calendarItem    ContentCalendarItem @relation(fields: [calendarItemId], references: [id])
  socialAccountId String
  socialAccount   SocialAccount @relation(fields: [socialAccountId], references: [id])

  postizPostId    String?
  status          PostStatus @default(SCHEDULED)
  publishedAt     DateTime?
  failureReason   String?
  postUrl         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────
// AUTOMATIONS
// ─────────────────────────────────────────────

model Automation {
  id          String   @id @default(cuid())
  creatorId   String
  creator     CreatorProfile @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  name        String
  isActive    Boolean  @default(true)
  platform    Platform
  triggerType AutomationTriggerType
  triggerKeyword String?   // e.g. "GUIDE", "LINK"
  postUrl     String?

  actions     AutomationAction[]
  events      AutomationEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AutomationAction {
  id           String   @id @default(cuid())
  automationId String
  automation   Automation @relation(fields: [automationId], references: [id], onDelete: Cascade)
  order        Int
  actionType   AutomationActionType
  template     String   // message template with {{variables}}
  delaySeconds Int?     @default(0)
  metadata     Json?
}

// ─────────────────────────────────────────────
// INSTAGRAM NATIVE INTEGRATION
// ─────────────────────────────────────────────

model IgConnection {
  id            String   @id @default(cuid())
  creatorId     String   @unique
  creator       CreatorProfile @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  igUserId      String   // Meta IG Business Account ID (numeric)
  igUsername    String
  pageId        String?  // Facebook Page ID linked to the IG Business account
  accessToken   String   // long-lived user access token (encrypted at rest ideally)
  tokenExpiry   DateTime?
  webhookActive Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Every person who has opted in (commented keyword, sent DM keyword, etc.)
model IgSubscriber {
  id            String   @id @default(cuid())
  creatorId     String
  creator       CreatorProfile @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  igUserId      String   // Meta user ID of the subscriber
  igUsername    String?
  firstName     String?
  lastName      String?
  tags          String[]
  source        String   // COMMENT_KEYWORD | DM_KEYWORD | STORY_MENTION
  optedInAt     DateTime @default(now())
  lastSeenAt    DateTime @default(now())

  events        AutomationEvent[]

  @@unique([creatorId, igUserId])
  @@index([creatorId])
}

// Audit log of every automation trigger
model AutomationEvent {
  id           String   @id @default(cuid())
  automationId String?
  automation   Automation?  @relation(fields: [automationId], references: [id])
  subscriberId String?
  subscriber   IgSubscriber? @relation(fields: [subscriberId], references: [id])

  eventType    String   // COMMENT_KEYWORD | DM_KEYWORD | STORY_MENTION | BROADCAST
  keyword      String?
  commentId    String?  // Meta comment ID
  messageId    String?  // Meta message ID
  status       String   @default("SENT") // SENT | FAILED | SKIPPED
  errorMsg     String?

  createdAt DateTime @default(now())

  @@index([automationId])
  @@index([subscriberId])
}

// ─────────────────────────────────────────────
// AI AVATAR & VOICE
// ─────────────────────────────────────────────

model AiVideoJob {
  id           String   @id @default(cuid())
  creatorId    String
  scriptId     String?
  heygenJobId  String?
  status       String   @default("pending")
  outputUrl    String?
  errorMsg     String?
  metadata     Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ─────────────────────────────────────────────
// BLOG ENGINE
// ─────────────────────────────────────────────

model BlogPost {
  id          String   @id @default(cuid())
  creatorId   String
  creator     CreatorProfile @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  scriptId    String?
  title       String
  slug        String
  content     String
  metaDescription String?
  tags        String[]
  status      ReviewStatus @default(PENDING)
  publishedAt DateTime?
  adminReview AdminReview?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([creatorId, slug])
}

// ─────────────────────────────────────────────
// ADMIN REVIEW
// ─────────────────────────────────────────────

model AdminReview {
  id        String       @id @default(cuid())
  ideaId    String?      @unique
  idea      ContentIdea? @relation(fields: [ideaId], references: [id])
  scriptId  String?      @unique
  script    Script?      @relation(fields: [scriptId], references: [id])
  blogId    String?      @unique
  blog      BlogPost?    @relation(fields: [blogId], references: [id])

  reviewerId String
  reviewer   User        @relation(fields: [reviewerId], references: [id])
  status     ReviewStatus @default(PENDING)
  notes      String?
  reviewedAt DateTime?

  createdAt DateTime @default(now())
}

// ─────────────────────────────────────────────
// BILLING & SUBSCRIPTIONS
// ─────────────────────────────────────────────

model Subscription {
  id               String             @id @default(cuid())
  organizationId   String
  organization     Organization       @relation(fields: [organizationId], references: [id])
  stripeCustomerId String?
  stripeSubId      String?            @unique
  tier             SubscriptionTier   @default(FREE)
  status           SubscriptionStatus @default(TRIALING)
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  cancelAtPeriodEnd  Boolean          @default(false)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
}

model BillingRecord {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  stripeInvoiceId String?  @unique
  amount         Int      // cents
  currency       String   @default("usd")
  status         String
  paidAt         DateTime?
  metadata       Json?
  createdAt      DateTime @default(now())
}

// ─────────────────────────────────────────────
// AUDIT LOG
// ─────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  action     String   // e.g. "SCRIPT_APPROVED", "VIDEO_DELETED"
  entityType String   // e.g. "Script", "Video"
  entityId   String
  meta       Json?
  ipAddress  String?
  createdAt  DateTime @default(now())

  @@index([userId, createdAt])
  @@index([entityType, entityId])
}
