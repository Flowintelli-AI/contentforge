{
  "framework": "nextjs",
  "installCommand": "cd ../.. && npm install",
  "buildCommand": "npx prisma generate --schema ../../packages/db/prisma/schema.prisma && npm run build",
  "outputDirectory": ".next",
  "regions": ["iad1"],
  "headers": [
    {
      "source": "/api/webhooks/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    }
  ]
}
