{
  "framework": "nextjs",
  "installCommand": "npm install",
  "buildCommand": "npm run build && cp -r apps/web/.next .next",
  "outputDirectory": ".next",
  "regions": ["iad1"],
  "crons": [
    {
      "path": "/api/cron/heygen-recover",
      "schedule": "0 2 * * *"
    }
  ],
  "headers": [
    {
      "source": "/api/webhooks/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    }
  ]
}
