{
  "framework": "nextjs",
  "installCommand": "npm install",
  "buildCommand": "npx next build",
  "outputDirectory": ".next",
  "regions": ["iad1"],
  "crons": [
    {
      "path": "/api/cron/heygen-recover",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/instagram-publish",
      "schedule": "*/5 * * * *"
    }
  ],
  "headers": [
    {
      "source": "/api/webhooks/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    }
  ]
}
